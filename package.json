{
  "name": "operator-control",
  "version": "0.4.0",
  "description": "Markdown-first Obsidian desktop home for Operator onboarding, native project setup, daily workflows, and agent runs.",
  "main": "main.js",
  "scripts": {
    "build": "tsc -noEmit && node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "package:plugin": "npm run build && node scripts/package-obsidian-plugin.mjs",
    "install:plugin": "npm run build && node scripts/install-obsidian-plugin.mjs",
    "test": "node scripts/run-tests.mjs",
    "check": "npm run test && npm run build"
  },
  "keywords": [
    "obsidian",
    "operator",
    "codex",
    "productivity"
  ],
  "author": "Herschel, based on Obsidian Operator by Yuhan Wang",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.25.0",
    "obsidian": "^1.8.7",
    "typescript": "^5.9.3"
  }
}
